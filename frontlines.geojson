fetch('frontlines.geojson')
  .then(res => {
    console.log("FRONTLINES STATUS:", res.status);
    return res.json();
  })
  .then(data => {
    console.log("FRONTLINES DATA:", data);

    L.geoJSON(data, {
      style: function(feature) {

        let faction = feature.properties?.faction;

        let color = "gray";
        if (faction === "SAF") color = "blue";
        if (faction === "RSF") color = "orange";

        return {
          color: color,
          weight: 3
        };
      }
    }).addTo(map);

  })
  .catch(err => console.log("FRONTLINES ERROR:", err));
